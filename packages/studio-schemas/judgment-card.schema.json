{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aikdna.com/schemas/judgment-card.schema.json",
  "title": "KDNA Judgment Card",
  "description": "A single unit of domain judgment inside a Studio Project.",
  "type": "object",
  "required": ["id", "type", "status"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Card identifier (e.g. ax_001, ms_003)."
    },
    "type": {
      "type": "string",
      "enum": ["axiom", "ontology", "misunderstanding", "boundary", "self_check", "risk", "aesthetic", "scenario", "case"],
      "description": "Card type determines which KDNA file it compiles into."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "revised", "locked", "tested", "published", "deprecated"],
      "description": "Current state in the card state machine."
    },
    "locked": {
      "type": "boolean",
      "description": "Convenience flag: true when status is locked, tested, or published."
    },
    "fields": {
      "type": "object",
      "description": "Type-specific fields. Must match the card type."
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to evidence entries that support this card."
    },
    "test_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to test cases linked to this card."
    },
    "human_lock": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["by", "at", "statement"],
          "properties": {
            "by": {
              "type": "string",
              "description": "Author identifier who locked this card."
            },
            "at": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp of lock."
            },
            "statement": {
              "type": "string",
              "description": "Expert's own words confirming this judgment represents their understanding."
            },
            "checked": {
              "type": "object",
              "properties": {
                "applies_when": { "type": "boolean" },
                "does_not_apply_when": { "type": "boolean" },
                "failure_risk": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },
    "feynman_restatement": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "The expert's restatement in simple terms a non-expert would understand."
            },
            "evaluated_at": {
              "type": "string",
              "format": "date-time"
            },
            "score": {
              "type": "object",
              "properties": {
                "not_just_repeat": { "type": "boolean" },
                "not_too_abstract": { "type": "boolean" },
                "has_concrete_example": { "type": "boolean" },
                "clarifies_boundary": { "type": "boolean" },
                "ordinary_person_understands": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },
    "audit_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "event", "by"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "event": { "type": "string", "enum": ["created", "revised", "locked", "unlocked", "tested", "published", "deprecated"] },
          "by": { "type": "string" },
          "changes": { "type": "array", "items": { "type": "string" } },
          "reason": { "type": "string" },
          "lock_statement": { "type": "string" }
        }
      }
    }
  }
}
